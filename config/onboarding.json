{
  "version": 1,
  "questions": [
    {
      "id": "focus",
      "prompt": "what best describes your current focus?",
      "type": "single",
      "options": [
        { "value": "design", "label": "design systems" },
        { "value": "engineering", "label": "engineering systems" },
        { "value": "strategy", "label": "strategy systems" }
      ],
      "next": "tempo"
    },
    {
      "id": "tempo",
      "prompt": "do you prefer structured pace or open exploration?",
      "type": "single",
      "options": [
        { "value": "structured", "label": "structured pace" },
        { "value": "open", "label": "open exploration" }
      ],
      "next": {
        "when": [{ "equals": "structured", "goto": "signal" }],
        "default": "signal"
      }
    },
    {
      "id": "signal",
      "prompt": "what signal matters most to you right now?",
      "type": "single",
      "options": [
        { "value": "clarity", "label": "clarity" },
        { "value": "velocity", "label": "velocity" },
        { "value": "depth", "label": "depth" }
      ],
      "next": "cadence"
    },
    {
      "id": "cadence",
      "prompt": "how often do you want to recalibrate?",
      "type": "single",
      "options": [
        { "value": "weekly", "label": "weekly" },
        { "value": "monthly", "label": "monthly" },
        { "value": "quarterly", "label": "quarterly" }
      ],
      "next": null
    }
  ]
}
{
  "branches": {
    "default": [
      {
        "id": "intent",
        "prompt": "What brings you to Otherhalf today?",
        "type": "single",
        "options": ["companionship", "clarity", "reinvention", "unknown"],
        "next": {
          "branches": {
            "companionship": "bond"
          },
          "default": "signal"
        }
      },
      {
        "id": "signal",
        "prompt": "How do you prefer to be guided?",
        "type": "single",
        "options": ["gentle", "direct", "experimental"],
        "next": "tempo"
      },
      {
        "id": "tempo",
        "prompt": "What rhythm feels right?",
        "type": "single",
        "options": ["slow burn", "balanced", "fast sync"],
        "next": "energy"
      },
      {
        "id": "energy",
        "prompt": "Choose a baseline energy level.",
        "type": "scale",
        "min": 1,
        "max": 5,
        "next": "presence"
      },
      {
        "id": "presence",
        "prompt": "How present should your otherhalf feel?",
        "type": "scale",
        "min": 1,
        "max": 5,
        "next": null
      }
    ],
    "bond": [
      {
        "id": "bond_style",
        "prompt": "Pick a bond style.",
        "type": "single",
        "options": ["devotional", "protective", "playful", "quiet"],
        "next": "bond_depth"
      },
      {
        "id": "bond_depth",
        "prompt": "How deep should the bond feel?",
        "type": "scale",
        "min": 1,
        "max": 5,
        "next": null
      }
    ]
  }
}
