# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- LLM (DeepSeek by default; OpenAI-compatible, swappable) ----
DEEPSEEK_API_KEY=
# optional overrides:
# LLM_API_KEY=            # falls back to DEEPSEEK_API_KEY
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=        # without the @, e.g. otherhalf_bot
TELEGRAM_WEBHOOK_SECRET=      # any random string; also pass to setWebhook

# ---- Stripe ----
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PRICE_ID=  # the recurring Price id (price_...)
STRIPE_WEBHOOK_SECRET=

# ---- App ----
NEXT_PUBLIC_APP_URL=          # e.g. https://otherhalf.example.com
